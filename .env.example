# Copy this file to `.env` for local development.

BASE_RPC_URL=https://mainnet.base.org
# Optional: reuse an already-running local Anvil Base fork for integration tests
# instead of letting the managed runner start an isolated local fork.
# If you set this, point it at a clean Base fork that you control.
BASE_LOCAL_ANVIL_URL=http://127.0.0.1:9545
# Optional: pin the real-active-pool replay test to a known live Base pool
# instead of scanning factory logs on each run.
BASE_ACTIVE_POOL_ADDRESS=
AJNA_KEEPER_PRIVATE_KEY=0xreplace_me
